# Site title
TITLE="NO CONVERSION THERAPY"

# Production: disable debug mode
DEBUG_MOD="false"

# Production: send submissions to Google Form for real
FORM_DRY_RUN="false"

# Public site URL, used by sitemap.xml and robots.txt
SITE_URL="https://your-domain.example"

# HTTP port
PORT="3000"

# Submission rate limit: max submissions within 15 minutes per client IP
SUBMIT_RATE_LIMIT_MAX="5"

# Form protection signing secret
# Generate one with: openssl rand -hex 32
FORM_PROTECTION_SECRET="replace-this-with-a-long-random-secret"

# Minimum time required before a form can be submitted, in milliseconds
FORM_PROTECTION_MIN_FILL_MS="3000"

# Maximum age of a form protection token, in milliseconds
FORM_PROTECTION_MAX_AGE_MS="86400000"

# Google Form ID
FORM_ID="1FAIpQLScggjQgYutXQrjQDrutyxL0eLaFMktTMRKsFWPffQGavUFspA"

# Google Apps Script API URL
# Set this if you have your own Apps Script data source
GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/your-script-id/exec"

# Public map data API
# If self-hosting without a private Apps Script source, this can point to your own public map API
PUBLIC_MAP_DATA_URL="https://your-domain.example/api/map-data"

# Production behind Nginx / Caddy / Vercel should usually enable trust proxy
TRUST_PROXY="1"

# Recommended for multi-instance deployments so rate limits are shared
# Leave empty if you only run a single app instance.
# When empty, the app falls back to in-memory rate limiting:
# - works on a single instance
# - resets when the app restarts
# - does not share limits across multiple instances
# TLS example: rediss://default:password@host:6379
RATE_LIMIT_REDIS_URL="rediss://default:password@your-redis-host:6379"
