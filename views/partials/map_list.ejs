<div class="form-group map-search-panel">
    <input type="text" name="search" id="mapSearchInput" placeholder="<%= t('map.list.searchPlaceholder') %>">
    <button id="mapSearchButton" type="button"><%= t('map.list.searchButton') %></button>
</div>


<div id="data-container" class="map-record-list"></div>
<div id="data-container-sentinel" class="map-record-list__status" aria-live="polite" hidden></div>

<script>
(() => {
    const i18n = window.I18N;
    const { buildSchoolReportStats, getSchoolReportStats, groupSchoolRecords } = window.MapRecordStats;
    const urlParams = new URLSearchParams(window.location.search);
    const inputType = urlParams.get('inputType');
    const inputSearch = (urlParams.get('search') || '').trim();
    const mapSearchInput = document.getElementById('mapSearchInput');
    const dataContainer = document.getElementById('data-container');
    const loadSentinel = document.getElementById('data-container-sentinel');
    const shouldTranslateDetails = window.APP_LANG !== 'zh-CN';
    const RECORD_BATCH_SIZE = 24;
    const RECORD_LOAD_ROOT_MARGIN = '1200px 0px 1200px 0px';
    let filteredRecords = [];
    let renderedRecordCount = 0;
    let recordsObserver = null;
    let scrollFallbackAttached = false;
    let schoolReportStatsBySchool = new Map();
    const originalChineseFieldLabels = {
        experience: '受害者经历：',
        scandal: '学校丑闻：',
        other: '其他：'
    };
    const translatableFieldConfigs = [
        {
            key: 'experience',
            sourceKey: 'experience',
            originalLabel: originalChineseFieldLabels.experience,
            translatedLabel: i18n.map.list.fields.experience
        },
        {
            key: 'scandal',
            sourceKey: 'scandal',
            originalLabel: originalChineseFieldLabels.scandal,
            translatedLabel: i18n.map.list.fields.scandal
        },
        {
            key: 'other',
            sourceKey: 'else',
            originalLabel: originalChineseFieldLabels.other,
            translatedLabel: i18n.map.list.fields.other
        }
    ];

    mapSearchInput.value = inputSearch;
    loadSentinel.textContent = i18n.common.loading;

    function formatMessage(template, values) {
        return Object.entries(values).reduce((result, [key, value]) => {
            return result.replaceAll(`{${key}}`, value);
        }, String(template || ''));
    }

    function normalizeSearchText(value) {
        return String(value || '').trim().toLowerCase().replace(/\s+/g, '');
    }

    function getInputTypeDisplay(value) {
        if (!value) {
            return i18n.data.inputTypes.bulk;
        }

        if (value === '受害者本人') {
            return i18n.data.inputTypes.self;
        }

        if (value === '受害者的代理人') {
            return i18n.data.inputTypes.agent;
        }

        if (value === '批量数据') {
            return i18n.data.inputTypes.bulk;
        }

        return value;
    }

    function getProvinceDisplay(value) {
        return i18n.data.provinceNames[value] || value || '';
    }

    function getSearchTokens(searchText) {
        return String(searchText || '')
            .trim()
            .toLowerCase()
            .split(/\s+/)
            .map((token) => normalizeSearchText(token))
            .filter(Boolean);
    }

    function getRecordAnchorId(index) {
        return `record-${index}`;
    }

    function getHashTargetIndex() {
        const match = window.location.hash.match(/^#record-(\d+)$/);
        if (!match) {
            return null;
        }

        const targetIndex = Number(match[1]);
        return Number.isInteger(targetIndex) ? targetIndex : null;
    }

    function matchesInputType(item, expectedInputType) {
        if (!expectedInputType) return true;
        if (expectedInputType === '批量数据') return !item.inputType;
        return item.inputType === expectedInputType;
    }

    function matchesSearch(item, searchText) {
        const searchTokens = getSearchTokens(searchText);
        if (searchTokens.length === 0) return true;

        const searchableFields = [
            item.name,
            item.experience,
            item.HMaster,
            item.province,
            getProvinceDisplay(item.province),
            item.prov,
            item.addr,
            item.scandal,
            item.contact,
            item.else,
            item.inputType,
            getInputTypeDisplay(item.inputType)
        ];

        const searchableText = searchableFields.map((field) => normalizeSearchText(field)).join(' ');
        return searchTokens.every((token) => searchableText.includes(token));
    }

    function escapeHtml(value) {
        return String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function getTranslationCacheKey(targetLanguage, text) {
        return `detail-translation:${targetLanguage}:${text}`;
    }

    function readTranslationCache(targetLanguage, text) {
        try {
            return window.sessionStorage.getItem(getTranslationCacheKey(targetLanguage, text));
        } catch (error) {
            console.warn('读取翻译缓存失败:', error);
            return null;
        }
    }

    function writeTranslationCache(targetLanguage, text, translatedText) {
        try {
            window.sessionStorage.setItem(getTranslationCacheKey(targetLanguage, text), translatedText);
        } catch (error) {
            console.warn('写入翻译缓存失败:', error);
        }
    }

    function getSourceTextByField(item, fieldConfig) {
        return String(item[fieldConfig.sourceKey] || '').trim();
    }

    function buildTranslatableSection(fieldKey, sourceText) {
        if (!sourceText) {
            return '';
        }

        const fieldConfig = translatableFieldConfigs.find((config) => config.key === fieldKey);
        if (!fieldConfig) {
            return '';
        }

        const originalHtml = `
            <div class="map-detail-block">
                <strong>${escapeHtml(fieldConfig.originalLabel)}</strong> ${escapeHtml(sourceText)}
            </div>
        `;

        if (!shouldTranslateDetails) {
            return originalHtml;
        }

        return `
            ${originalHtml}
            <div class="map-detail-block map-detail-block--translation" data-translate-field="${fieldKey}">
                <strong>${escapeHtml(fieldConfig.translatedLabel)}</strong>
                <span class="map-detail-translation__text">${escapeHtml(i18n.map.list.translationLoading)}</span>
            </div>
        `;
    }

    async function requestTranslations(items) {
        const response = await window.fetch('/api/translate-text', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                targetLanguage: window.APP_LANG,
                items
            })
        });

        const payload = await response.json();
        if (!response.ok) {
            throw new Error(payload.error || i18n.map.list.translationUnavailable);
        }

        return Array.isArray(payload.translations) ? payload.translations : [];
    }

    async function hydrateTranslations(container, item) {
        if (!shouldTranslateDetails || container.dataset.translationState === 'loaded' || container.dataset.translationState === 'loading') {
            return;
        }

        const itemsToTranslate = translatableFieldConfigs
            .map((config) => ({
                fieldKey: config.key,
                text: getSourceTextByField(item, config)
            }))
            .filter((entry) => entry.text);

        if (itemsToTranslate.length === 0) {
            container.dataset.translationState = 'loaded';
            return;
        }

        const translatedTextByField = Object.create(null);
        const pendingItems = [];

        itemsToTranslate.forEach((entry) => {
            const cachedTranslation = readTranslationCache(window.APP_LANG, entry.text);

            if (cachedTranslation) {
                translatedTextByField[entry.fieldKey] = cachedTranslation;
            } else {
                pendingItems.push(entry);
            }
        });

        container.dataset.translationState = 'loading';

        try {
            if (pendingItems.length > 0) {
                const translatedItems = await requestTranslations(pendingItems);
                translatedItems.forEach((entry) => {
                    translatedTextByField[entry.fieldKey] = entry.translatedText || '';

                    if (entry.translatedText) {
                        writeTranslationCache(window.APP_LANG, entry.text, entry.translatedText);
                    }
                });
            }

            itemsToTranslate.forEach((entry) => {
                const targetNode = container.querySelector(`[data-translate-field="${entry.fieldKey}"] .map-detail-translation__text`);

                if (targetNode) {
                    targetNode.textContent = translatedTextByField[entry.fieldKey] || i18n.map.list.translationUnavailable;
                }
            });

            container.dataset.translationState = 'loaded';
        } catch (error) {
            console.error('翻译详情失败:', error);
            itemsToTranslate.forEach((entry) => {
                const targetNode = container.querySelector(`[data-translate-field="${entry.fieldKey}"] .map-detail-translation__text`);

                if (targetNode) {
                    targetNode.textContent = i18n.map.list.translationUnavailable;
                }
            });
            container.dataset.translationState = 'error';
        }
    }

    function triggerMapSearch() {
        queryUpd('search', mapSearchInput.value);
    }

    mapSearchInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
            event.preventDefault();
            triggerMapSearch();
        }
    });

    document.getElementById('mapSearchButton').addEventListener('click', triggerMapSearch);

    function disconnectLoadWatcher() {
        if (recordsObserver) {
            recordsObserver.disconnect();
            recordsObserver = null;
        }

        if (scrollFallbackAttached) {
            window.removeEventListener('scroll', handleWindowScrollLoad);
            scrollFallbackAttached = false;
        }
    }

    function updateLoadSentinel() {
        const hasMoreRecords = renderedRecordCount < filteredRecords.length;
        loadSentinel.hidden = !hasMoreRecords;
        loadSentinel.textContent = hasMoreRecords ? i18n.common.loading : '';

        if (!hasMoreRecords) {
            disconnectLoadWatcher();
        }
    }

    function buildRecordBodyHtml(item, currentPage, totalPages) {
        const experienceHtml = buildTranslatableSection('experience', item.experience);
        const scandalHtml = buildTranslatableSection('scandal', item.scandal);
        const elseHtml = buildTranslatableSection('other', item.else);
        const paginationHtml = totalPages > 1 ? `
            <div class="map-record-pagination">
                <button
                    type="button"
                    class="map-record-pagination__button"
                    data-page-action="prev"
                    ${currentPage === 0 ? 'disabled' : ''}
                >${escapeHtml(i18n.map.list.pagination.previous)}</button>
                <span class="map-record-pagination__status">${escapeHtml(formatMessage(i18n.map.list.pagination.page, {
                    current: currentPage + 1,
                    total: totalPages
                }))}</span>
                <button
                    type="button"
                    class="map-record-pagination__button"
                    data-page-action="next"
                    ${currentPage >= totalPages - 1 ? 'disabled' : ''}
                >${escapeHtml(i18n.map.list.pagination.next)}</button>
            </div>
        ` : '';

        return `
            <p><strong>${escapeHtml(i18n.map.list.fields.headmaster)}</strong>${escapeHtml(item.HMaster)}</p>
            <p><strong>${escapeHtml(i18n.map.list.fields.province)}</strong>${escapeHtml(getProvinceDisplay(item.province))}</p>
            <p><strong>${escapeHtml(i18n.map.list.fields.region)}</strong>${escapeHtml(item.prov)}</p>
            <p><strong>${escapeHtml(i18n.map.list.fields.address)}</strong>${escapeHtml(item.addr)}</p>
            <hr>
            ${experienceHtml}
            ${scandalHtml}
            ${elseHtml}
            <div class="contact"><strong>${escapeHtml(i18n.map.list.fields.contact)}</strong>\n${escapeHtml(item.contact)}</div>
            ${paginationHtml}
        `;
    }

    function createRecordCard(group, index) {
        const card = document.createElement('details');
        card.className = 'div map-record-card';
        card.id = getRecordAnchorId(index);
        card.style.width = '100%';

        const summaryRecord = group.summaryRecord;
        const pages = group.pages;
        const schoolReportStats = getSchoolReportStats(schoolReportStatsBySchool, summaryRecord);
        let currentPageIndex = 0;

        card.innerHTML = `
            <summary class="map-record-summary">
                <div class="map-record-summary__title-group">
                    <h3 class="map-record-summary__title">${escapeHtml(summaryRecord.name)}</h3>
                </div>
                <small class="map-record-summary__tag">
                    <span class="map-record-summary__count">${escapeHtml(i18n.map.list.reportCounts.self)} ${schoolReportStats.selfCount}</span>
                    <span class="map-record-summary__count">${escapeHtml(i18n.map.list.reportCounts.agent)} ${schoolReportStats.agentCount}</span>
                </small>
            </summary>
            <div class="div map-record-body"></div>
        `;

        const bodyContainer = card.querySelector('.map-record-body');

        function renderRecordPage() {
            const currentRecord = pages[currentPageIndex];
            bodyContainer.innerHTML = buildRecordBodyHtml(currentRecord, currentPageIndex, pages.length);
            bodyContainer.dataset.translationState = '';

            const prevButton = bodyContainer.querySelector('[data-page-action="prev"]');
            const nextButton = bodyContainer.querySelector('[data-page-action="next"]');

            if (prevButton) {
                prevButton.addEventListener('click', () => {
                    if (currentPageIndex <= 0) {
                        return;
                    }

                    currentPageIndex -= 1;
                    renderRecordPage();
                });
            }

            if (nextButton) {
                nextButton.addEventListener('click', () => {
                    if (currentPageIndex >= pages.length - 1) {
                        return;
                    }

                    currentPageIndex += 1;
                    renderRecordPage();
                });
            }

            if (card.open) {
                hydrateTranslations(bodyContainer, currentRecord);
            }
        }

        renderRecordPage();

        if (shouldTranslateDetails) {
            card.addEventListener('toggle', () => {
                if (card.open) {
                    hydrateTranslations(bodyContainer, pages[currentPageIndex]);
                }
            });
        }

        return card;
    }

    function renderRecordsThroughIndex(targetIndex) {
        const nextCount = Math.min(filteredRecords.length, targetIndex + 1);
        if (nextCount <= renderedRecordCount) {
            updateLoadSentinel();
            return;
        }

        const fragment = document.createDocumentFragment();

        for (let index = renderedRecordCount; index < nextCount; index += 1) {
            fragment.appendChild(createRecordCard(filteredRecords[index], index));
        }

        dataContainer.appendChild(fragment);
        renderedRecordCount = nextCount;
        updateLoadSentinel();
    }

    function renderNextBatch() {
        renderRecordsThroughIndex(renderedRecordCount + RECORD_BATCH_SIZE - 1);
    }

    function scrollRecordIntoView(targetIndex) {
        const targetCard = document.getElementById(getRecordAnchorId(targetIndex));

        if (!targetCard) {
            return;
        }

        window.requestAnimationFrame(() => {
            targetCard.scrollIntoView({ block: 'start' });
        });
    }

    function ensureHashTargetIsRendered() {
        const targetIndex = getHashTargetIndex();

        if (targetIndex === null || targetIndex < 0 || targetIndex >= filteredRecords.length) {
            return;
        }

        if (renderedRecordCount <= targetIndex) {
            renderRecordsThroughIndex(targetIndex);
        }

        scrollRecordIntoView(targetIndex);
    }

    function handleWindowScrollLoad() {
        if (loadSentinel.hidden) {
            return;
        }

        const sentinelTop = loadSentinel.getBoundingClientRect().top;
        if (sentinelTop <= window.innerHeight + 1200) {
            renderNextBatch();
        }
    }

    function observeLoadSentinel() {
        disconnectLoadWatcher();

        if (filteredRecords.length <= renderedRecordCount) {
            updateLoadSentinel();
            return;
        }

        if ('IntersectionObserver' in window) {
            recordsObserver = new IntersectionObserver((entries) => {
                if (entries.some((entry) => entry.isIntersecting)) {
                    renderNextBatch();
                }
            }, {
                rootMargin: RECORD_LOAD_ROOT_MARGIN
            });

            recordsObserver.observe(loadSentinel);
            return;
        }

        window.addEventListener('scroll', handleWindowScrollLoad, { passive: true });
        scrollFallbackAttached = true;
        handleWindowScrollLoad();
    }

    function resetRenderedRecords(nextRecords) {
        disconnectLoadWatcher();
        filteredRecords = nextRecords;
        renderedRecordCount = 0;
        dataContainer.innerHTML = '';
        loadSentinel.hidden = true;
        loadSentinel.textContent = '';
    }

    async function loadData() {
        try {
            const response = await window.getSharedMapData();
            const rawData = response.data;
            schoolReportStatsBySchool = buildSchoolReportStats(rawData);
            const nextFilteredRecords = rawData.filter((item) => matchesInputType(item, inputType) && matchesSearch(item, inputSearch));
            const nextFilteredGroups = groupSchoolRecords(nextFilteredRecords);

            resetRenderedRecords(nextFilteredGroups);

            if (filteredRecords.length === 0) {
                dataContainer.innerHTML = `<p>${escapeHtml(i18n.map.list.noResults)}</p>`;
                return;
            }

            renderNextBatch();
            observeLoadSentinel();
            ensureHashTargetIsRendered();
        } catch (error) {
            console.error('獲取數據失敗:', error);
            resetRenderedRecords([]);
            document.getElementById('data-container').innerHTML = `<p>${escapeHtml(i18n.map.list.loadFailed)}</p>`;
        }
    }

    window.addEventListener('hashchange', ensureHashTargetIsRendered);

    // 執行函數
    loadData();
})();
</script>
