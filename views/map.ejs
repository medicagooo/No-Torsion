<%- include('partials/head') %>
<html>
<head>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <style>
        .map-page {
            --map-content-width: min(70%, 1100px);
        }

        .map-page > *:not(.page-back-link):not(#backToTop):not(script) {
            width: var(--map-content-width);
            box-sizing: border-box;
        }

        .map-page .map-section-title {
            border-left: 4px solid var(--primary);
            padding-left: 15px;
            margin-top: 30px;
            color: var(--primary);
        }

        @media (max-width: 650px) {
            .map-page {
                --map-content-width: 95%;
            }
        }

        @media (max-width: 480px) {
            .map-page {
                --map-content-width: calc(100% - 1rem);
            }
        }
    </style>
</head>
<body class="map-page">
    <a href="/" class="page-back-link">← <%= t('navigation.home') %></a>
    <script src="/js/map_data_store.js"></script>
    <script src="/js/map_time_utils.js"></script>
    <script src="/js/map_record_stats.js"></script>
    <h1><%= t('map.title') %></h1>
    <h2 class="map-section-title"><%= t('map.sections.stats') %></h2>
    <%- include('partials/map_allnum') %>
    <h2 class="map-section-title"><%= t('map.sections.tags') %></h2>
    <%- include('partials/map_tag') %>
    <h2 class="map-section-title"><%= t('map.sections.map') %></h2>
    <small><%= t('map.note') %></small>
    <div id="map" class="div"></div>
    <%- include('partials/map_apimd') %>
    <h2 class="map-section-title"><%= t('map.sections.allData') %></h2>
    <%- include('partials/map_list') %>
    <button id="backToTop" type="button">↑</button>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/js/map_api.js"></script>
    <%- include('partials/foot') %>
</body>
</html>
